{
	"$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
	"files": {
		"includes": [
			"**/*",
			"!**/.next",
			"!**/node_modules",
			"!**/storybook-static",
			"!**/tsconfig.tsbuildinfo"
		]
	},
	"linter": {
		"rules": {
			"recommended": true
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single"
		}
	},
	"css": {
		"formatter": {
			"quoteStyle": "single"
		}
	},
	"assist": {
		"actions": { "source": { "organizeImports": "on" } }
	}
}
